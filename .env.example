# AGENTIC ZERO — Environment Variables
# Copia este archivo como .env y rellena los valores

# ── PROJECT ──────────────────────────────
PROJECT_NAME=agentic-zero
VERSION=0.1.0
ENVIRONMENT=development

# ── LLM PROVIDER ─────────────────────────
# Fase 1-2: Groq (gratuito, 100K tokens/día)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=groq/llama-3.3-70b-versatile

# Fase 3+: Anthropic Claude
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# Fase alternativa: Google Gemini
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini/gemini-2.0-flash

# ── LIBRARY ──────────────────────────────
LIBRARY_PATH=F:/agentic-zero/library

# ── LOGGING ──────────────────────────────
LOG_LEVEL=INFO

# ── API (futuro M7) ───────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── QUEUE (futuro M8) ─────────────────────
QUEUE_BROKER=redis://localhost:6379/0
