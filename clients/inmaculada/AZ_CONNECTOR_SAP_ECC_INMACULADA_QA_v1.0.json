        "priority":    "high",
        "trigger":     "Inmaculada TMS pendiente documentacion Carlos Mendoza",
        "delta_from_ecc": "Pure REST -- no SAP dependency"
      },
      {
        "id":          "ORACLE-ERP",
        "priority":    "medium",
        "trigger":     "Segundo cliente potencial sector pharma",
        "delta_from_ecc": "SOAP/REST APIs -- different auth model"
      },
      {
        "id":          "MS-DYNAMICS-365",
        "priority":    "medium",
        "trigger":     "Standard tier clients -- frequent ERP",
        "delta_from_ecc": "OAuth2 + REST -- well documented"
      },
      {
        "id":          "EMAIL-PDF-READER",
        "priority":    "medium",
        "trigger":     "Inmaculada pago anticipado extractos bancarios",
        "delta_from_ecc": "IMAP + PDF parser -- no ERP dependency"
      }
    ]
  }
}
