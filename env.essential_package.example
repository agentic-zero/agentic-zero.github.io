# AGENTIC ZERO -- Essential Package Pipeline -- Path Configuration
# Apunta el pipeline FA -> SIOP -> Validator -> Blueprint a la estructura
# estandar de carpeta cliente (essential_package/) en lugar de library/
#
# Cargar este .env ANTES de ejecutar customer_pipeline.py para un cliente
# que usa la convencion 01_..09_ + delivery_manifest.json
#
# Si no se carga, el pipeline sigue funcionando pero escribe en
# library/functional_analysis/, library/siop_internal/, etc.
# (comportamiento legacy, compatible con flujos anteriores)

# ── Ajustar SOLO esta linea por cliente/proceso ────────────────────────────
PACKAGE_DIR=clients/inmaculada/otc/essential_package

# ── No tocar -- derivadas automaticamente de PACKAGE_DIR ──────────────────
FUNCTIONAL_ANALYSIS_PATH=${PACKAGE_DIR}/01_functional_analysis
SIOP_INTERNAL_PATH=${PACKAGE_DIR}/02_siop
SIOP_VALIDATION_PATH=${PACKAGE_DIR}/02_siop
BLUEPRINT_PATH=${PACKAGE_DIR}/03_blueprint

# ── Library global -- compartida entre todos los clientes ─────────────────
LIBRARY_PATH=library
